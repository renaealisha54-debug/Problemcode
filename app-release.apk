

Y('pc_workspace');
    if (saved) setCode(saved);
  }, []);

  useEffect(() => {
    localStorage.setItem('pc_workspace', code);
  }, [code]);

  const runCode = async () => {
    const res = await fetch('/api/execute', {
      method: 'POST',
      body: JSON.stringify({ code, language }),
      headers: { 'Content-Type': 'application/json' }
    });
    const data = await res.json();
    setOutput(data.result);
  };

  const generateAPK = async () => {
    setIsBuilding(true);
    const res = await fetch('/api/generate-apk', {
      method: 'POST',
      body: JSON.stringify({ code }),
      headers: { 'Content-Type': 'application/json' }
    });
    // Trigger download of the generated blob
    const blob = await res.blob();
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = "ProblemCode_Export.apk";
    a.click();
    setIsBuilding(false);
  };

  return (
    <div className="flex flex-col h-screen bg-[#1e1e1e] text-white">
      {/* Toolbar */}
      <div className="flex p-2 bg-[#2d2d2d] gap-4 items-center">
        <h1 className="font-bold text-blue-400">ProblemCode</h1>
        <button onClick={runCode} className="flex items-center gap-1 bg-green-600 px-3 py-1 rounded"><Play size={16}/> Run</button>
        <button className="flex items-center gap-1 bg-purple-600 px-3 py-1 rounded"><Sparkles size={16}/> AI Fix</button>
        <button onClick={generateAPK} disabled={isBuilding} className="flex items-center gap-1 bg-blue-600 px-3 py-1 rounded">
          <Smartphone size={16}/> {isBuilding ? "Building..." : "Export APK"}
        </button>
      </div>

      {/* Main Workspace */}
      <div className="flex flex-1 overflow-hidden">
        <Editor 
          height="100%" 
          theme="vs-dark"
          language={language}
          value={code}
          onChange={(val) => setCode(val)}
        />
        <div className="w-1/3 bg-black p-4 font-mono text-sm overflow-y-auto">
          <div className="text-gray-500 mb-2 border-b border-gray-800">Console Output</div>
          {output}
        </div>
      </div>
    </div>
  );
}
